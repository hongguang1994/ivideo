# 复制为 .env 并按需修改（docker compose 会自动读取）。

# OpenList 登录凭据（后端调用其 API 用）。
# 首次启动后到日志里拿初始密码，或在 OpenList 后台改密后填这里。
OPENLIST_USERNAME=admin
OPENLIST_PASSWORD=

# 视频根目录：OpenList 中挂载点下存放视频的路径，例如 /aliyun/videos。
# 留空或 / 表示从根目录开始浏览。
OPENLIST_ROOT=/

# ---- Jellyfin（可选）----
# 后端连 Jellyfin 的地址，容器内默认走服务名，无需改动。
JELLYFIN_BASE_URL=http://jellyfin:8096
# 在 Jellyfin 后台 -> 控制台 -> API 密钥 里生成后填这里。
# 留空则后端不启用 Jellyfin 源，前端只显示网盘文件。
JELLYFIN_API_KEY=

# ---- 按需转存缓存 ----
# 缓存盘适配器：fake(本地联调，用示例视频) / aliyun(阿里云盘，待实现)
CACHE_BACKEND=fake
# 自己网盘里存缓存文件的目录
CACHE_DIR=/ivideo-cache
# 缓存总量上限(字节)，超过按 LRU 淘汰。默认 200GB
CACHE_MAX_BYTES=214748364800
# 超过多久没看就清理(小时)
CACHE_TTL_HOURS=72
# 清理任务间隔(分钟)
CACHE_CLEAN_INTERVAL_MINUTES=10

# ---- 阿里云盘适配器(Share2Open 转存缓存)----
# 启用方式:把上面的 CACHE_BACKEND 改成 aliyun。
# web refresh token(小雅的 /etc/xiaoya/mytoken.txt):做 取分享token / 转存
ALIYUN_REFRESH_TOKEN=
# 开放接口 refresh token(小雅的 /etc/xiaoya/myopentoken.txt):做 取直链 / 删除
ALIYUN_OPEN_REFRESH_TOKEN=
# 开放平台应用凭据(可用你自己的阿里开放应用,或小雅那套)
ALIYUN_OPEN_CLIENT_ID=
ALIYUN_OPEN_CLIENT_SECRET=
# 开放接口换 token 地址(默认官方;小雅用自己的代理地址 oauth_token_url)
ALIYUN_OPEN_TOKEN_URL=https://openapi.alipan.com/oauth/access_token
# 转存目标临时目录的 file_id(小雅的 /etc/xiaoya/temp_transfer_folder_id.txt);root 表示网盘根
ALIYUN_TEMP_FOLDER_ID=root
# 自己盘 drive_id;留空则从 token 自动获取
ALIYUN_DRIVE_ID=
# ⚠️ 阿里 refresh token 会轮换,勿与小雅共用同一 token(会互相挤下线),建议用专用小号。
